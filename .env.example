# ============================================================
# 猕猴桃智慧种植与产销一体化 AI Agent 平台
# 环境配置文件
# 使用说明: 复制此文件为 .env 并修改相应的配置值
#   cp .env.example .env
# ============================================================

# --- 应用基础配置 ---
APP_NAME=kiwi-ai-platform
APP_ENV=development
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production
API_PREFIX=/api/v1

# --- 大模型配置 (支持多模型切换) ---
# 可选值: dashscope, openai, anthropic, ollama
# 默认使用 dashscope (阿里百炼)，无需本地部署 Ollama
LLM_PROVIDER=dashscope
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# 阿里百炼 DashScope (默认推荐，无需本地部署模型)
# 获取 API Key: https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=your-dashscope-api-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 可选模型: qwen-plus, qwen-max, qwen-turbo
DASHSCOPE_MODEL=qwen-plus

# OpenAI (可选)
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Anthropic Claude (可选)
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Ollama (本地部署可选，需要额外安装 Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# --- 数据库配置 ---
# PostgreSQL (业务数据)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=kiwi_admin
POSTGRES_PASSWORD=kiwi_secure_password
POSTGRES_DB=kiwi_platform

# InfluxDB (IoT 时序数据)
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=kiwi-influx-token
INFLUXDB_ORG=kiwi-org
INFLUXDB_BUCKET=kiwi-iot

# ChromaDB (向量数据库/RAG)
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_IS_PERSISTENT=True

# Redis (缓存/消息队列)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# --- Celery 异步任务 ---
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- IoT 配置 ---
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USERNAME=kiwi_mqtt
MQTT_PASSWORD=kiwi_mqtt_password
MQTT_TOPIC_PREFIX=kiwi/iot

# --- 文件存储 ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# --- CORS 配置 ---
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# --- 日志配置 ---
LOG_LEVEL=DEBUG
LOG_FORMAT=json
