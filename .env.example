# ============================================================
# 猕猴桃智慧种植与产销一体化 AI Agent 平台
# 环境配置文件
# ============================================================

# --- 应用基础配置 ---
APP_NAME=kiwi-ai-platform
APP_ENV=development
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production
API_PREFIX=/api/v1

# --- 大模型配置 (支持多模型切换) ---
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:7b
LLM_BASE_URL=http://localhost:11434
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# OpenAI (可选)
OPENAI_API_KEY=sk-5c971168dda343889dc09e69800dc29b
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=gpt-4o

# Anthropic Claude (可选)
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Ollama (本地部署推荐)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# --- 数据库配置 ---
# PostgreSQL (业务数据)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=kiwi_admin
POSTGRES_PASSWORD=kiwi_secure_password
POSTGRES_DB=kiwi_platform

# InfluxDB (IoT 时序数据)
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=kiwi-influx-token
INFLUXDB_ORG=kiwi-org
INFLUXDB_BUCKET=kiwi-iot

# ChromaDB (向量数据库/RAG)
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_IS_PERSISTENT=True

# Redis (缓存/消息队列)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# --- Celery 异步任务 ---
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- IoT 配置 ---
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USERNAME=kiwi_mqtt
MQTT_PASSWORD=kiwi_mqtt_password
MQTT_TOPIC_PREFIX=kiwi/iot

# --- 文件存储 ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# --- CORS 配置 ---
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# --- 日志配置 ---
LOG_LEVEL=DEBUG
LOG_FORMAT=json
